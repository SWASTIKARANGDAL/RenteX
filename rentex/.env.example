# ─────────────────────────────────────────────
# RenteX Environment Configuration
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Django Core
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Email (use console backend for development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For production with Gmail:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=RenteX <noreply@rentex.com>

# Payment Gateway (razorpay or stripe)
PAYMENT_GATEWAY=razorpay

# Razorpay (get keys at https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Stripe (get keys at https://dashboard.stripe.com)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret

# Twilio SMS (optional - for SMS notifications)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Celery (optional - for async tasks, use Redis)
CELERY_BROKER_URL=redis://localhost:6379/0

# Google OAuth (optional - for social login)
# Configure at https://console.developers.google.com
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-secret
